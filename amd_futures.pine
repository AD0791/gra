// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//@version=6
indicator("AMD FVG Trade Setup [LuxAlgo]", shorttitle="AMD FVG", overlay=true, max_boxes_count=500, max_labels_count=500)

// =============================================================================
// Section 1 — User Inputs
// =============================================================================
GRP_AMD = "AMD Logic"
accLen       = input.int(20,   "Accumulation Length", minval=5, group=GRP_AMD)
accWidth     = input.float(0.15, "Accumulation Range Max %", minval=0.01, step=0.05, group=GRP_AMD)
manLook      = input.int(25,   "Max Search Window", minval=1, group=GRP_AMD)
fvgThreshold = input.float(0.1, "Min FVG Gap (ATR Multiplier)", minval=0.0, step=0.05, group=GRP_AMD)

GRP_TRADE = "Trade Settings"
atrLen  = input.int(14,   "ATR Length", group=GRP_TRADE)
atrMult = input.float(2.0, "ATR SL Multiplier", step=0.1, group=GRP_TRADE)
rrr     = input.float(2.0, "Reward-to-Risk Ratio", step=0.1, group=GRP_TRADE)

GRP_SESS = "Sessions (EST)"
useSydney = input.bool(false, "Sydney", group=GRP_SESS)
useTokyo  = input.bool(false, "Tokyo", group=GRP_SESS)
useLondon = input.bool(false, "London", group=GRP_SESS)
useNY     = input.bool(true,  "New York", group=GRP_SESS)
showSess  = input.bool(true,  "Highlight Sessions", group=GRP_SESS)

GRP_COL = "Colors"
accColor  = input.color(color.new(color.gray, 85), "Accumulation", group=GRP_COL)
manColor  = input.color(color.new(#f23645, 80),    "Manipulation (Bear)", group=GRP_COL)
manColorB = input.color(color.new(#089981, 80),    "Manipulation (Bull)", group=GRP_COL)
tpColor   = input.color(color.new(#089981, 80),    "Take Profit", group=GRP_COL)
slColor   = input.color(color.new(#f23645, 80),    "Stop Loss", group=GRP_COL)
fvgColor  = input.color(color.new(color.white, 70), "FVG Highlight", group=GRP_COL)

// =============================================================================
// Section 2 — Helper Logic
// =============================================================================
inSession(sess) => not na(time(timeframe.period, sess, "America/New_York"))

isInSession = (useSydney and inSession("1700-0200")) or
              (useTokyo  and inSession("1900-0400")) or
              (useLondon and inSession("0300-1200")) or
              (useNY     and inSession("0800-1700"))

bgcolor(showSess and isInSession ? color.new(color.blue, 98) : na)
atr = ta.atr(atrLen)

// =============================================================================
// Section 3 — State Variables
// =============================================================================
var float accH = na, var float accL = na
var int accStartTime = na, var int accEndTime = na
var bool hasManipH = false, var bool hasManipL = false
var float manipExt = na, var int manipEndTime = na

var box tpBox = na, var box slBox = na
var float tpPrice = na, var float slPrice = na
var bool isTradeActive = false, var bool isBullish = false

// =============================================================================
// Section 4 — Accumulation Detection
// =============================================================================
hVal = ta.highest(high, accLen)
lVal = ta.lowest(low, accLen)
rangePct = (hVal - lVal) / lVal * 100
isAcc = rangePct <= accWidth and isInSession

if isAcc
    accH := hVal
    accL := lVal
    accStartTime := time[accLen - 1]
    accEndTime := time
    hasManipH := false
    hasManipL := false
    manipExt := na
    manipEndTime := na

// =============================================================================
// Section 5 — Trade Management
// =============================================================================
if isTradeActive
    tpBox.set_right(time_close)
    slBox.set_right(time_close)
    if isBullish
        if low <= slPrice or high >= tpPrice
            isTradeActive := false
    else
        if high >= slPrice or low <= tpPrice
            isTradeActive := false

// =============================================================================
// Section 6 — AMD Logic (Strictly using TIME for sync)
// =============================================================================
canSearch = not isAcc and not na(accH) and time <= accEndTime + (manLook * timeframe.in_seconds() * 1000)

if canSearch
    // Bearish Logic
    if not hasManipH and not hasManipL and high > accH
        hasManipH := true
        manipExt := high
    
    if hasManipH
        manipExt := math.max(manipExt, high)
        // FVG Check: Gap between bar 2 low and current high
        isBearFVG = (low[2] - high) > (atr * fvgThreshold) and close < accH
        
        if isBearFVG and not isTradeActive
            // Draw Accumulation
            box.new(accStartTime, accH, accEndTime, accL, bgcolor=accColor, border_color=na, xloc=xloc.bar_time)
            // Draw Manipulation (from end of acc to start of FVG)
            box.new(accEndTime, manipExt, time[2], accH, bgcolor=manColor, border_color=na, xloc=xloc.bar_time)
            // Draw FVG
            box.new(time[2], low[2], time, high, bgcolor=fvgColor, border_color=na, xloc=xloc.bar_time)
            
            slPrice := close + (atr * atrMult)
            tpPrice := close - (atr * atrMult * rrr)
            isTradeActive := true
            isBullish := false
            
            tpBox := box.new(time, close, time_close, tpPrice, bgcolor=tpColor, border_color=na, xloc=xloc.bar_time)
            slBox := box.new(time, close, time_close, slPrice, bgcolor=slColor, border_color=na, xloc=xloc.bar_time)
            label.new(time, high, "AMD Bear", color=color.red, style=label.style_label_down, textcolor=color.white, size=size.tiny, xloc=xloc.bar_time)
            accH := na // Reset

    // Bullish Logic
    if not hasManipL and not hasManipH and low < accL
        hasManipL := true
        manipExt := low
        
    if hasManipL
        manipExt := math.min(manipExt, low)
        // FVG Check: Gap between current low and bar 2 high
        isBullFVG = (low - high[2]) > (atr * fvgThreshold) and close > accL
        
        if isBullFVG and not isTradeActive
            box.new(accStartTime, accH, accEndTime, accL, bgcolor=accColor, border_color=na, xloc=xloc.bar_time)
            box.new(accEndTime, accL, time[2], manipExt, bgcolor=manColorB, border_color=na, xloc=xloc.bar_time)
            box.new(time[2], high[2], time, low, bgcolor=fvgColor, border_color=na, xloc=xloc.bar_time)
            
            slPrice := close - (atr * atrMult)
            tpPrice := close + (atr * atrMult * rrr)
            isTradeActive := true
            isBullish := true
            
            tpBox := box.new(time, close, time_close, tpPrice, bgcolor=tpColor, border_color=na, xloc=xloc.bar_time)
            slBox := box.new(time, close, time_close, slPrice, bgcolor=slColor, border_color=na, xloc=xloc.bar_time)
            label.new(time, low, "AMD Bull", color=color.green, style=label.style_label_up, textcolor=color.white, size=size.tiny, xloc=xloc.bar_time)
            accH := na // Reset

// Cleanup if search window expires
if time > accEndTime + (manLook * timeframe.in_seconds() * 1000)
    accH := na
